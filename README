 cargo run -p relay
 cargo build --release -p client

 curl -fsSL https://raw.githubusercontent.com/Manojseetaram/cli-chat-tool/main/install.sh | bash





 
irm https://raw.githubusercontent.com/Manojseetaram/cli-chat-tool/main/install.ps1 | iex

#Mac/linux
RELAY=cli-chat-tool-g1n0.onrender.com viva
# PowerShell
$env:RELAY="cli-chat-tool-g1n0.onrender.com"; viva

# CMD
set RELAY=cli-chat-tool-g1n0.onrender.com && viva.exe


rustup target add x86_64-pc-windows-gnu
brew install mingw-w64
cargo build --release -p client --target x86_64-pc-windows-gnu

#target/x86_64-pc-windows-gnu/release/viva-windows-x86_64.exe
cargo build --release -p client
cp target/release/client ~/.local/bin/viva
viva  # should now say "Connecting to cli-chat-tool-g1n0.onrender.com"